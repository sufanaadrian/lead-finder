# Copy this file to ".env.local" and fill in the values below.
# How to get them: see README.md → "Setup"
GOOGLE_PLACES_API_KEY=

# Supabase project settings (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose this one to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Shared login for the deployed app (Basic Auth) — keeps strangers who find
# the URL from using it / burning the Google budget. Leave APP_PASSWORD blank
# to disable (fine for local dev; set it before deploying anywhere public).
APP_USER=lead-finder
APP_PASSWORD=
